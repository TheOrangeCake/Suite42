SPRING_PROFILES_ACTIVE=prod

# =====================================================================
# VAULT SEED FILE
# These values are used ONLY to initialize HashiCorp Vault on first run.
# Services do NOT read from this file directly -- they receive secrets
# from Vault via generated env files at container startup.
#
# SETUP:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in the values marked with <...>
#   3. Run:  make
#
# For 42 OAuth credentials:
#   - Go to https://profile.intra.42.fr/oauth/applications
#   - Create an app with redirect URI: https://localhost/api/auth/login/oauth2/code/42
#   - Copy the UID and SECRET below
#
# For email (2FA for regular users):
#   - Use a Gmail address with an App Password
#   - https://myaccount.google.com/apppasswords
# =====================================================================

#---- Non-secret configuration (used directly by docker-compose) ----
POSTGRES_DB=transcendence
POSTGRES_USER=transcendence
FORTYTWO_REDIRECT_URI=https://localhost/api/auth/login/oauth2/code/42
API42_POSTGRES_DB=api42db
API42_POSTGRES_USER=api42user
REGULAR_USER_POSTGRES_DB=regularuserdb
REGULAR_USER_POSTGRES_USER=regularuser
VITE_API_URL=https://localhost

#---- Secrets (seeded into Vault by vault-init, then served to services) ----
POSTGRES_PASSWORD=transcendence_pass
FORTYTWO_CLIENT_ID=<your-42-app-uid>
FORTYTWO_CLIENT_SECRET=<your-42-app-secret>
JWT_SECRET=super-secret-jwt-key-that-is-long-enough-for-hmac-sha256-algorithm!!
API42_POSTGRES_PASSWORD=api42pass
API42_NEXT_SECRET=test_api42_next_secret
REGULAR_USER_POSTGRES_PASSWORD=regularuserpass
REGULAR_USER_JWT_KEY=368b1dfa9820d60f3815a7d42c471e775bddc4392ca677d4ddfc2b3b42fed5de
REGULAR_USER_EMAIL=<your-gmail@gmail.com>
REGULAR_USER_APP_PASSWORD=<your-gmail-app-password>
